{
  "app": {
    "id": "AgenticOS.Notifications",
    "displayName": "Agentic OS",
    "shortcutName": "Agentic OS Notifications",
    "assetVersion": "v4",
    "attribution": "Agentic OS",
    "defaultDuration": "short",
    "defaultLayout": "compact"
  },
  "assets": {
    "logoPath": "assets/windows-notify/scrapes_logo.jpg",
    "shortcutIconPath": "assets/windows-notify/scrapes_logo.ico",
    "heroPaths": {
      "success": "",
      "info": "",
      "warning": "",
      "error": ""
    },
    "generatedLogo": {
      "badgeText": "AO",
      "startColor": "#0F172A",
      "endColor": "#1D4ED8",
      "overlayColor": "#FFFFFF",
      "overlayOpacity": 52,
      "borderColor": "#FFFFFF",
      "borderOpacity": 140,
      "textColor": "#F8FAFC"
    },
    "variants": {
      "success": {
        "startColor": "#0F4D38",
        "endColor": "#0AA36C",
        "accentColor": "#DCFCE7",
        "sound": "ms-winsoundevent:Notification.Default",
        "emoji": "✅"
      },
      "info": {
        "startColor": "#102C63",
        "endColor": "#2F6BFF",
        "accentColor": "#DBEAFE",
        "sound": "ms-winsoundevent:Notification.IM",
        "emoji": "💡"
      },
      "warning": {
        "startColor": "#6B3B06",
        "endColor": "#F59E0B",
        "accentColor": "#FEF3C7",
        "sound": "ms-winsoundevent:Notification.Reminder",
        "emoji": "⚠️"
      },
      "error": {
        "startColor": "#63171B",
        "endColor": "#E11D48",
        "accentColor": "#FFE4E6",
        "sound": "ms-winsoundevent:Notification.Mail",
        "emoji": "🚨"
      }
    }
  },
  "copy": {
    "interactive": {
      "waiting": {
        "status": "Needs input",
        "subject": "{project}",
        "detail": "Claude is paused until you reply.",
        "variant": "info",
        "duration": "long",
        "layout": "compact"
      },
      "permission": {
        "status": "Permission required",
        "subject": "{project}",
        "detail": "{rawMessage}",
        "variant": "warning",
        "duration": "long",
        "layout": "compact"
      },
      "actionRequired": {
        "status": "Needs attention",
        "subject": "{project}",
        "detail": "{rawMessage}",
        "variant": "warning",
        "duration": "long",
        "layout": "compact"
      },
      "complete": {
        "status": "Task complete",
        "subject": "{project}",
        "detail": "Job #{seq} finished in {duration}.",
        "variant": "success",
        "duration": "short",
        "layout": "compact"
      }
    },
    "cron": {
      "success": {
        "status": "Task complete",
        "subject": "{jobName}{catchUpSuffix}",
        "detail": "Completed in {duration}.",
        "variant": "success",
        "duration": "short",
        "layout": "compact"
      },
      "timeout": {
        "status": "Timed out",
        "subject": "{jobName}{catchUpSuffix}",
        "detail": "Killed after the {timeout} limit.",
        "variant": "warning",
        "duration": "short",
        "layout": "compact"
      },
      "failure": {
        "status": "Needs attention",
        "subject": "{jobName}{catchUpSuffix}",
        "detail": "Exit code {exitCode} after {duration}.",
        "variant": "error",
        "duration": "short",
        "layout": "compact"
      }
    }
  }
}
