    {"type":"text","id":"rule","x":1340,"y":900,"width":540,"height":140,"text":"NON-NEGOTIABLE\n\nOnly ONE active GSD per workspace.\n.planning/ is shared — must be\narchived before the next GSD starts.","originalText":"NON-NEGOTIABLE\n\nOnly ONE active GSD per workspace.\n.planning/ is shared — must be\narchived before the next GSD starts.","fontSize":15,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#EF6351","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":400023,"version":1,"versionNonce":400024,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.5},

