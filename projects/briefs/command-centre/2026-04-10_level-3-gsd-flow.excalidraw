    {"type":"text","id":"why_body","x":1340,"y":220,"width":500,"height":140,"text":"• complex multi-phase work\n• hard dependencies between phases\n• needs verification loop\n• benefits from .planning/ lifecycle","originalText":"• complex multi-phase work\n• hard dependencies between phases\n• needs verification loop\n• benefits from .planning/ lifecycle","fontSize":16,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#2D2D2D","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":400003,"version":1,"versionNonce":400004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.5},

