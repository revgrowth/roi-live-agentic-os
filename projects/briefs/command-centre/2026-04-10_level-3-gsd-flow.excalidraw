    {"type":"text","id":"drill_body","x":1340,"y":430,"width":500,"height":160,"text":"• View Phases\n• Sync Phases\n• Badge: uses .planning/ slot\n• If not active → Open active GSD\n• Canonical workspace: /gsd","originalText":"• View Phases\n• Sync Phases\n• Badge: uses .planning/ slot\n• If not active → Open active GSD\n• Canonical workspace: /gsd","fontSize":16,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#2D2D2D","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":400007,"version":1,"versionNonce":400008,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.5},

