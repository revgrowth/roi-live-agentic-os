    {"type":"text","id":"override","x":30,"y":1720,"width":1900,"height":25,"text":"Override: Pick mode forces GSD directly — but guardrail still runs. Blocked path has no Start button, only Open/Archive — user must resolve before a new GSD can begin.","originalText":"Override: Pick mode forces GSD directly — but guardrail still runs. Blocked path has no Start button, only Open/Archive — user must resolve before a new GSD can begin.","fontSize":15,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#2D2D2D","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":500001,"version":1,"versionNonce":500002,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25}
