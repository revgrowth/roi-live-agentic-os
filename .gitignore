# Secrets
.env
.mcp.json

# User data (created per-install)
context/memory/*
!context/memory/.gitkeep
projects/*
!projects/.gitkeep
brand_context/*.md
!brand_context/.gitkeep

# Installer state
.claude/skills/_catalog/installed.json

# Local settings
.claude/settings.local.json
.claude/hooks_info/ccnotify.db
.claude/hooks_info/ccnotify.log*

# System
.DS_Store
.backup/

# Cron (logs and status are runtime, specific personal jobs excluded)
cron/jobs/claude-code-trending.md
cron/jobs/nano-banana-trending.md
cron/jobs/test-watchdog.md
cron/logs/
cron/status/

# Client workspaces (all client data is local)
clients/
